# Use MONGO_URI for Atlas or local MongoDB URI for development.
MONGO_URI=mongodb://localhost:27017/proconnect
# Optionally set a local fallback when Atlas is configured:
# MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/proconnect
JWT_SECRET=your_jwt_secret_here
